    "@diffdash/app",
    "@diffdash/domain",
    "@diffdash/download-worker",
    "@diffdash/e2e",
    "@diffdash/git-provider",
    "@diffdash/git-provider-fixture",
    "@diffdash/git-provider-github",
    "@diffdash/local-git",
    "@diffdash/persistence",
    "@diffdash/process",
    "@diffdash/protocol",
    "@diffdash/review-agent",
    "@diffdash/settings",
    "@diffdash/walkthrough",
    "@diffdash/web",
    "@diffdash/demo",
    "@diffdash/demo-video"
