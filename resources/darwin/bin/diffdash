#!/bin/sh
set -eu

usage() {
  printf '%s\n' \
    'Usage: diffdash [path]' \
    '       diffdash install [path]'
}

for argument in "$@"; do
  case "$argument" in
    -h|--help)
      usage
      exit 0
      ;;
  esac
done

target_argument='--diffdash-local-path'
target_path="${1:-$PWD}"

if [ "${1:-}" = 'install' ]; then
  shift

  for argument in "$@"; do
    case "$argument" in
      -*)
        printf 'Unknown option for `diffdash install`: %s\n' "$argument" >&2
        printf '%s\n' 'Usage: diffdash install [path]' >&2
        exit 2
        ;;
    esac
  done

  if [ "$#" -gt 1 ]; then
    printf '%s\n' \
      'diffdash install accepts at most one path.' \
      'Usage: diffdash install [path]' >&2
    exit 2
  fi

  target_argument='--diffdash-link-path'
  target_path="${1:-$PWD}"
  case "$target_path" in
    /*) ;;
    *) target_path="$PWD/$target_path" ;;
  esac
fi

self_path="$0"
if command -v readlink >/dev/null 2>&1; then
  resolved_path="$(readlink "$0" 2>/dev/null || true)"
  if [ -n "$resolved_path" ]; then
    case "$resolved_path" in
      /*) self_path="$resolved_path" ;;
      *) self_path="$(dirname "$0")/$resolved_path" ;;
    esac
  fi
fi

contents_dir="$(dirname "$(dirname "$(dirname "$self_path")")")"
app_binary="$contents_dir/MacOS/DiffDash"

if [ ! -x "$app_binary" ]; then
  app_binary='/Applications/DiffDash.app/Contents/MacOS/DiffDash'
fi

if [ ! -x "$app_binary" ]; then
  printf '%s\n' 'Could not find the installed DiffDash app binary.' >&2
  exit 1
fi

"$app_binary" "$target_argument=$target_path" >/dev/null 2>&1 &
