#!/bin/sh
set -eu

usage() {
  printf '%s\n' \
    'Usage: diffdash [path]' \
    '       diffdash install [path]' \
    '       diffdash pr [pr-number]' \
    '       diffdash diff [branch-name]'
}

for argument in "$@"; do
  case "$argument" in
    -h|--help)
      usage
      exit 0
      ;;
  esac
done

self_path="$0"
if command -v readlink >/dev/null 2>&1; then
  resolved_path="$(readlink "$0" 2>/dev/null || true)"
  if [ -n "$resolved_path" ]; then
    case "$resolved_path" in
      /*) self_path="$resolved_path" ;;
      *) self_path="$(dirname "$0")/$resolved_path" ;;
    esac
  fi
fi

contents_dir="$(dirname "$(dirname "$(dirname "$self_path")")")"
app_binary="$contents_dir/MacOS/DiffDash"

if [ ! -x "$app_binary" ]; then
  app_binary='/Applications/DiffDash.app/Contents/MacOS/DiffDash'
fi

if [ ! -x "$app_binary" ]; then
  printf '%s\n' 'Could not find the installed DiffDash app binary.' >&2
  exit 1
fi

"$app_binary" "--diffdash-cli-v1=$PWD" -- "$@" >/dev/null 2>&1 &
