#!/bin/sh
set -eu

usage() {
  printf '%s\n' \
    'Usage: diffdash [path]' \
    '       diffdash install [path]' \
    '       diffdash pr [pr-number]' \
    '       diffdash diff [branch-name]'
}

for argument in "$@"; do
  case "$argument" in
    -h|--help)
      usage
      exit 0
      ;;
  esac
done

if command -v readlink >/dev/null 2>&1; then
  self_path="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
else
  self_path="$0"
fi

app_binary="${DIFFDASH_APPIMAGE_PATH:-}"
if [ -z "$app_binary" ]; then
  app_root="$(dirname "$(dirname "$(dirname "$self_path")")")"
  app_binary="$app_root/diffdash-desktop"
fi

if [ ! -x "$app_binary" ]; then
  for candidate in \
    '/opt/DiffDash/diffdash-desktop' \
    '/opt/diffdash/diffdash-desktop' \
    '/usr/lib/diffdash/diffdash-desktop'
  do
    if [ -x "$candidate" ]; then
      app_binary="$candidate"
      break
    fi
  done
fi

if [ ! -x "$app_binary" ]; then
  printf '%s\n' 'Could not find the installed DiffDash app binary.' >&2
  exit 1
fi

"$app_binary" --diffdash-cli-v1 "$PWD" -- "$@" >/dev/null 2>&1 &
