#!/bin/sh
set -eu

usage() {
  printf '%s\n' \
    'Usage: diffdash [path]' \
    '       diffdash install [path]'
}

for argument in "$@"; do
  case "$argument" in
    -h|--help)
      usage
      exit 0
      ;;
  esac
done

target_argument='--diffdash-local-path'
target_path="${1:-$PWD}"

if [ "${1:-}" = 'install' ]; then
  shift

  for argument in "$@"; do
    case "$argument" in
      -*)
        printf 'Unknown option for `diffdash install`: %s\n' "$argument" >&2
        printf '%s\n' 'Usage: diffdash install [path]' >&2
        exit 2
        ;;
    esac
  done

  if [ "$#" -gt 1 ]; then
    printf '%s\n' \
      'diffdash install accepts at most one path.' \
      'Usage: diffdash install [path]' >&2
    exit 2
  fi

  target_argument='--diffdash-link-path'
  target_path="${1:-$PWD}"
  case "$target_path" in
    /*) ;;
    *) target_path="$PWD/$target_path" ;;
  esac
fi

if command -v readlink >/dev/null 2>&1; then
  self_path="$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")"
else
  self_path="$0"
fi

app_root="$(dirname "$(dirname "$(dirname "$self_path")")")"
app_binary="$app_root/diffdash-desktop"

if [ ! -x "$app_binary" ]; then
  for candidate in \
    '/opt/DiffDash/diffdash-desktop' \
    '/opt/diffdash/diffdash-desktop' \
    '/usr/lib/diffdash/diffdash-desktop'
  do
    if [ -x "$candidate" ]; then
      app_binary="$candidate"
      break
    fi
  done
fi

if [ ! -x "$app_binary" ]; then
  printf '%s\n' 'Could not find the installed DiffDash app binary.' >&2
  exit 1
fi

"$app_binary" "$target_argument=$target_path" >/dev/null 2>&1 &
