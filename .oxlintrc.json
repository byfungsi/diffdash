{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "plugins": [
    "typescript",
    "oxc",
    "unicorn",
    "react",
    "react-perf",
    "jsx-a11y",
    "import",
    "promise",
    "node",
    "vitest"
  ],
  "jsPlugins": [
    {
      "name": "react-doctor",
      "specifier": "oxlint-plugin-react-doctor"
    }
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "ignorePatterns": [
    "node_modules/**",
    "**/out/**",
    "**/dist/**",
    "**/coverage/**",
    "*.tsbuildinfo"
  ],
  "rules": {
    "no-console": "warn",
    "import/no-unassigned-import": "off",
    "react/react-in-jsx-scope": "off",
    "react/jsx-key": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/rules-of-hooks": "error",
    "react-perf/jsx-no-new-array-as-prop": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-new-object-as-prop": "off",
    "react-doctor/no-fetch-in-effect": "warn",
    "react-doctor/no-derived-state-effect": "warn",
    "react-doctor/rules-of-hooks": "error"
  },
  "overrides": [
    {
      "files": [
        "packages/desktop/electron/**/*.ts",
        "packages/desktop/src/main/**/*.ts",
        "packages/desktop/scripts/**/*.mjs",
        "scripts/**/*.mjs"
      ],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["packages/app/src/components/ui/**/*.tsx"],
      "rules": {
        "react-perf/jsx-no-new-array-as-prop": "off",
        "react-perf/jsx-no-new-function-as-prop": "off",
        "react-perf/jsx-no-new-object-as-prop": "off"
      }
    },
    {
      "files": [
        "packages/agent-provider/src/**/*.{ts,tsx}",
        "packages/app/src/**/*.{ts,tsx}",
        "packages/domain/src/**/*.{ts,tsx}",
        "packages/git-provider/src/**/*.{ts,tsx}",
        "packages/protocol/src/**/*.{ts,tsx}"
      ],
      "rules": {
        "import/no-nodejs-modules": "error",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:better-sqlite3|electron(?:-updater)?|@diffdash/(?:agent-provider-.+|desktop|git-provider-.+|persistence|process))(?:/|$)",
                "message": "Browser-safe packages cannot import platform or concrete provider modules."
              },
              {
                "regex": "(?:^|/)src/main(?:/|$)",
                "message": "Browser-safe packages cannot import main-process modules."
              }
            ]
          }
        ]
      }
    },
    {
      "files": [
        "packages/agent-provider-*/src/**/*.{ts,tsx}",
        "packages/git-provider-*/src/**/*.{ts,tsx}"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:electron(?:-updater)?|react(?:-dom)?|better-sqlite3|@diffdash/(?:app|desktop|persistence|settings))(?:/|$)",
                "message": "Concrete providers are platform-neutral leaf integrations."
              },
              {
                "regex": "^@diffdash/(?:agent-provider|git-provider)/registry$",
                "message": "Concrete providers cannot depend on the registry implementation."
              },
              {
                "regex": "^@diffdash/(?:agent-provider-|git-provider-)",
                "message": "Concrete providers cannot import another concrete provider."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "no-console": "off",
        "vitest/no-standalone-expect": "off"
      }
    }
  ]
}
