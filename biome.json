{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!**/out",
      "!**/dist",
      "!**/.turbo",
      "!**/coverage",
      "!**/test-results",
      "!**/release-assets",
      "!demo/.cache",
      "!media/.cache",
      "!media/output",
      "!media/public/audio",
      "!media/public/captures",
      "!media/public/fonts",
      "!tools/promo-capture/.cache",
      "!tools/promo-media/.cache",
      "!tools/promo-media/output",
      "!tools/promo-media/public/audio",
      "!tools/promo-media/public/captures",
      "!tools/promo-media/public/fonts",
      "!pnpm-lock.yaml",
      "!*.tsbuildinfo"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded"
    }
  },
  "linter": {
    "enabled": false
  },
  "assist": {
    "enabled": false
  }
}
