{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**"]
    },
    "@diffdash/download-worker#build": {
      "outputs": []
    },
    "@diffdash/demo#build": {
      "outputs": []
    },
    "@diffdash/promo-capture#build": {
      "outputs": [".cache/host/**"]
    },
    "@diffdash/promo-media#build": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "capture": {
      "cache": false
    },
    "render": {
      "dependsOn": ["@diffdash/promo-capture#capture"],
      "cache": false
    },
    "render:vertical": {
      "dependsOn": ["@diffdash/promo-capture#capture"],
      "cache": false
    },
    "render:all": {
      "dependsOn": ["@diffdash/promo-capture#capture"],
      "cache": false
    },
    "e2e": {
      "dependsOn": ["@diffdash/desktop#build"],
      "cache": false
    },
    "package:e2e": {
      "cache": false
    },
    "e2e:packaged": {
      "dependsOn": ["@diffdash/e2e#package:e2e"],
      "cache": false
    }
  }
}
