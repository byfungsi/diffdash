{
  "name": "diffdash-landing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "check:worker": "node --check worker/index.js",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "deploy": "pnpm check:worker && pnpm build && wrangler deploy",
    "deploy:dry-run": "pnpm check:worker && pnpm build && wrangler deploy --dry-run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "wrangler": "^4.52.0"
  }
}
