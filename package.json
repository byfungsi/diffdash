{
  "name": "diffdash",
  "productName": "DiffDash",
  "version": "0.1.4",
  "description": "Desktop code review app with Effect-powered TypeScript services.",
  "type": "module",
  "main": "out/main/index.js",
  "bin": {
    "diffdash": "bin/diffdash.mjs"
  },
  "scripts": {
    "assets:icons": "node scripts/generate-icons.mjs",
    "dev": "pnpm assets:icons && pnpm native:electron && electron-vite dev",
    "build": "electron-vite build",
    "pack": "pnpm assets:icons && pnpm native:electron && pnpm build && electron-builder --dir --publish=never",
    "dist": "pnpm assets:icons && pnpm native:electron && pnpm build && electron-builder --publish=never",
    "dist:mac": "pnpm assets:icons && pnpm native:electron && pnpm build && electron-builder --mac dmg zip --publish=never",
    "dist:linux": "pnpm assets:icons && pnpm native:electron && pnpm build && electron-builder --linux AppImage deb --publish=never",
    "dist:linux:deb": "pnpm assets:icons && pnpm native:electron && pnpm build && electron-builder --linux deb --publish=never",
    "dist:win": "pnpm assets:icons && pnpm native:electron && pnpm build && electron-builder --win nsis --publish=never",
    "changeset": "changeset",
    "release:check": "pnpm assets:icons && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:browser && pnpm test:e2e",
    "release:local": "node scripts/release-local.mjs",
    "release:local:mac": "node scripts/build-local-mac-release.mjs",
    "release:local:linux": "node scripts/build-local-linux-release.mjs",
    "release:local:publish": "node scripts/publish-release-assets.mjs",
    "release:notes": "node scripts/extract-release-notes.mjs",
    "release:tag": "node scripts/create-release-tag.mjs",
    "release:version": "changeset version",
    "preview": "electron-vite preview",
    "prepare": "effect-language-service patch && node scripts/install-husky.mjs",
    "typecheck": "tsc --noEmit",
    "test": "pnpm native:node && vitest run",
    "test:browser": "vitest --config vitest.browser.config.ts run",
    "test:e2e": "pnpm native:electron && pnpm build && pnpm exec electron --version && playwright test",
    "test:all": "pnpm test && pnpm test:browser && pnpm test:e2e",
    "test:watch": "vitest",
    "lint": "oxlint . --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --no-error-on-unmatched-pattern",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "native:electron": "npm_config_runtime=electron npm_config_target=43.0.0 npm_config_disturl=https://electronjs.org/headers node scripts/rebuild-better-sqlite3.mjs",
    "native:node": "node scripts/rebuild-better-sqlite3.mjs"
  },
  "keywords": [],
  "author": "Muhammad Hanif",
  "license": "ISC",
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@effect-atom/atom-react": "^0.5.0",
    "@pierre/diffs": "^1.2.12",
    "@pierre/trees": "1.0.0-beta.5",
    "@radix-ui/react-slot": "^1.3.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.4",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.86.4",
    "@effect/vitest": "^0.29.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^3.2.7",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.73.0",
    "oxlint-plugin-react-doctor": "^0.7.1",
    "playwright": "^1.61.1",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  },
  "build": {
    "appId": "dev.diffdash.app",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/**/*.node"
    ],
    "removePackageScripts": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "icon": "resources/icons/icon.icns",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ],
      "type": "distribution",
      "extraResources": [
        {
          "from": "resources/darwin/bin/diffdash",
          "to": "bin/diffdash"
        }
      ]
    },
    "dmg": {
      "backgroundColor": "#111827",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "category": "Development",
      "executableName": "diffdash-desktop",
      "icon": "resources/icons/png",
      "target": [
        "AppImage",
        "deb"
      ],
      "extraResources": [
        {
          "from": "resources/linux/bin/diffdash",
          "to": "bin/diffdash"
        }
      ]
    },
    "deb": {
      "maintainer": "Muhammad Hanif <pocisite@gmail.com>",
      "afterInstall": "resources/linux/deb/after-install.sh",
      "afterRemove": "resources/linux/deb/after-remove.sh"
    },
    "win": {
      "icon": "resources/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "oneClick": false,
      "perMachine": false
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
